{
  "name": "dfd-inventory-staging",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:configure": "node scripts/configure-cloudflare.mjs",
    "cf:check": "wrangler check",
    "cf:typegen": "wrangler types",
    "deploy": "npm run deploy:staging",
    "deploy:staging": "npm run build && npm run cf:check && wrangler deploy",
    "deploy:production": "npm run build && npm run cf:check && wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply dfd_inventory --local",
    "db:migrate:remote": "npm run db:migrate:remote:staging",
    "db:migrate:remote:staging": "wrangler d1 migrations apply dfd_inventory --remote",
    "db:migrate:remote:production": "wrangler d1 migrations apply dfd_inventory_prod --remote --env production"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.11.0",
    "@cloudflare/workers-types": "^4.20260610.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.21.0"
  }
}
